{
  "global": {
    "train": "../multilingual-segmentation-dataset/data/segmented/split/multilingual/train.json",
    "test": "../multilingual-segmentation-dataset/data/segmented/split/multilingual/test.json",
    "dev": "../multilingual-segmentation-dataset/data/segmented/split/multilingual/dev.json",
    "out_dir": "/home/mgl/Documents/test_working",
    "import": "",
    "device": "cpu",
    "base_model_name": "google-bert/bert-base-multilingual-cased",
    "data_augmentation": false,
    "freeze_embeddings": true,
    "emb_dim": 768,
    "freeze_lang_embeddings": false,
    "linear_layers": 3,
    "linear_layers_hidden_size": 128,
    "balance_class_weights": false,
    "include_lang_metadata": false,
    "lang_emb_dim": 16,
    "epochs": 1,
    "use_pretrained_embeddings": false,
    "use_bert_tokenizer": false,
    "lr": 0.0006,
    "workers": 16,
    "batch_size": 48,
    "segments_max_length": 25,
    "eval_batch_size": 48,
    "use_char_embeddings": true
  },
  "architectures": {
    "lstm": {
    "char_dropout_prob": 0.05,
    "char_embedding_dim": 48,
      "bidirectional": true,
      "lstm_dropout": 0.550,
      "positional_embeddings": false,
      "linear_dropout": 0.04,
      "keep_bert_dimensions": false,
      "lstm_hidden_size": 136,
      "num_lstm_layers": 2,
      "add_attention_layer": true
    },
    "gru": {
      "bidirectional": false,
      "dropout": 0.03,
      "positional_embeddings": false,
      "hidden_size": 64,
      "num_layers": 2,
      "linear_layers_hidden_size": 128,
      "add_attention_layer": false
    },
    "transformer": {
      "num_heads": 8,
      "num_transformers_layers": 8
    },
    "cnn": {
      "hidden_size": 64,
      "linear_layers": 2,
      "positional_embeddings": true,
      "add_attention_layer": true,
      "keep_bert_dimensions": true,
      "num_heads": 8,
      "kernel_size": 5,
      "dropout": 0.5,
      "cnn_scale": 0.5,
      "num_cnn_layers": 10
    }
  }
}
